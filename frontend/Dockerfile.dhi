FROM dhi.io/node:24-dev AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci --legacy-peer-deps

COPY . .
RUN npm run build

FROM dhi.io/node:24 AS runtime

WORKDIR /app

ENV NODE_ENV=production \
    NITRO_HOST=0.0.0.0 \
    NITRO_PORT=3000

COPY --from=build /app/.output /app/.output

EXPOSE 3000
USER 1000:1000

CMD ["node", ".output/server/index.mjs"]
